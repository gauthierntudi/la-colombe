# Copier vers .env.local
# cp apps/admin/.env.example apps/admin/.env.local

# ─── Requis ───────────────────────────────────────────────────────────────────

# Neon PostgreSQL — console.neon.tech → Connection string (pooled)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require"

# Secrets JWT (générer avec: openssl rand -base64 48)
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# ─── Flexpaie (Phase 3 — Mobile Money, optionnel en Phase 1) ─────────────────

# Dashboard Flexpaie → clés API marchand
FLEXPAIE_API_KEY=""
FLEXPAIE_MERCHANT_ID=""

# Secret pour vérifier les webhooks (générer avec: openssl rand -hex 32)
FLEXPAIE_WEBHOOK_SECRET=""

# URL publique de l'app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret pour cron expiration factures (openssl rand -hex 32)
CRON_SECRET=""

# ─── Amazon S3 (images produits, avatars) ────────────────────────────────────

# Nom du compartiment — permissions IAM requises sur ce bucket
S3_BUCKET="assets-colombe"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Optionnel — URL publique personnalisée (CloudFront, etc.)
# S3_PUBLIC_URL_BASE="https://cdn.example.com"
